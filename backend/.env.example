# ========================================
# CraftedLoop - Environment Variables
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - add it to .gitignore!

# ========================================
# SUPABASE CONFIGURATION
# ========================================
# Get these from your Supabase project dashboard:
# Settings → API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for client-side use)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (KEEP SECRET - server-side only!)
# Only use this in Edge Functions or server-side code
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========================================
# APPLICATION SETTINGS
# ========================================

# Application name
VITE_APP_NAME=CraftedLoop

# Base URL for your application
VITE_APP_URL=http://localhost:5173

# Production URL (update when deploying)
VITE_APP_PRODUCTION_URL=https://craftedloop.in

# API base path (if using custom API routes)
VITE_API_BASE_URL=/api

# ========================================
# RAZORPAY CONFIGURATION (Optional)
# ========================================
# Sign up at https://razorpay.com and get your keys from Settings → API Keys

# Razorpay Key ID (public - safe for client-side)
VITE_RAZORPAY_KEY_ID=rzp_test_your-key-id

# Razorpay Key Secret (KEEP SECRET - server-side only!)
VITE_RAZORPAY_KEY_SECRET=your-key-secret

# Razorpay Webhook Secret (for payment confirmations)
VITE_RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ========================================
# EMAIL CONFIGURATION (Optional)
# ========================================
# For sending order confirmations and notifications

# SMTP host (e.g., smtp.gmail.com)
VITE_SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL)
VITE_SMTP_PORT=587

# SMTP username (your email)
VITE_SMTP_USERNAME=your-email@gmail.com

# SMTP password (app password for Gmail)
VITE_SMTP_PASSWORD=your-app-password

# From email address
VITE_EMAIL_FROM=noreply@craftedloop.in

# Support email
VITE_EMAIL_SUPPORT=hello@craftedloop.in

# ========================================
# WHATSAPP BUSINESS API (Optional)
# ========================================
# For order notifications via WhatsApp

# WhatsApp Business API URL
VITE_WHATSAPP_API_URL=https://api.whatsapp.com

# WhatsApp Business phone number (with country code, no +)
VITE_WHATSAPP_PHONE=919876543210

# ========================================
# GST CONFIGURATION
# ========================================

# GST rate for products (in percentage)
VITE_GST_RATE=18

# Free shipping threshold (orders above this get free shipping)
VITE_FREE_SHIPPING_THRESHOLD=1500

# Default shipping charge
VITE_DEFAULT_SHIPPING_CHARGE=100

# ========================================
# SECURITY & ANALYTICS (Optional)
# ========================================

# Google Analytics ID
VITE_GA_ID=G-XXXXXXXXXX

# Google Tag Manager ID
VITE_GTM_ID=GTM-XXXXXXX

# reCAPTCHA site key (for form protection)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# reCAPTCHA secret key (server-side only)
VITE_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# ========================================
# DEVELOPMENT SETTINGS
# ========================================

# Enable debug mode (don't use in production)
VITE_DEBUG=false

# Enable mock data (for development without backend)
VITE_USE_MOCK_DATA=false

# Log level (debug, info, warn, error)
VITE_LOG_LEVEL=debug

# ========================================
# STORAGE SETTINGS
# ========================================

# Maximum file upload size (in bytes)
VITE_MAX_UPLOAD_SIZE=5242880

# Allowed image types for upload
VITE_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

# ========================================
# BUSINESS SETTINGS
# ========================================

# Business phone number (for WhatsApp link)
VITE_BUSINESS_PHONE=919876543210

# Business email
VITE_BUSINESS_EMAIL=hello@craftedloop.in

# Business address
VITE_BUSINESS_ADDRESS=123 Artisan Lane, Bandra West, Jammu, Maharashtra 400050

# Working hours
VITE_BUSINESS_HOURS=Monday - Saturday: 10:00 AM - 7:00 PM

# ========================================
# NOTES
# ========================================
#
# 1. Environment variables prefixed with VITE_ are exposed to the client
# 2. Never expose sensitive keys (service role, secrets) to the client
# 3. Use Edge Functions for server-side operations requiring secret keys
# 4. Update VITE_APP_URL when deploying to production
# 5. Keep .env file secure and never commit to version control
#
# To use this file:
# 1. Copy to .env: cp .env.example .env
# 2. Fill in your actual values
# 3. Restart your development server
#
# ========================================
