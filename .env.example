# Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
# SANITY CMS (Optional - defaults are already in code)
# ═══════════════════════════════════════════════════════════════

# Sanity Project ID (default: 2r50s816)
VITE_SANITY_PROJECT_ID=2r50s816

# Sanity Dataset (default: production)
VITE_SANITY_DATASET=production

# Sanity API Token (only needed for write operations from frontend)
# Generate at: https://www.sanity.io/manage/project/2r50s816/api#tokens
# VITE_SANITY_API_TOKEN=your_token_here

# ═══════════════════════════════════════════════════════════════
# FIREBASE (if using Firebase features)
# ═══════════════════════════════════════════════════════════════

# VITE_FIREBASE_API_KEY=your_api_key
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
# VITE_FIREBASE_APP_ID=your_app_id
